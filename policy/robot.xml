<mujoco model="biped_robot">
  <compiler angle="degree" inertiafromgeom="true" />
  <option integrator="RK4" timestep="0.002" />
  <default>
    <joint armature="0.01" damping="0.1" limited="true" />
    <geom conaffinity="1" condim="3" contype="1" friction="0.9 0.1 0.1" density="1000" />
  </default>
  <worldbody>
    <light pos="0 0 1.3" dir="0 0 -1" diffuse="1 1 1" />
    <geom name="floor" type="plane" pos="0 0 0" size="40 40 40" rgba="0.8 0.9 0.8 1" />
    <body name="torso" pos="0 0 1.25">
      <joint name="torso_x" type="slide" axis="1 0 0" limited="false" />
      <joint name="torso_y" type="hinge" axis="0 1 0" limited="false" />
      <joint name="torso_z" type="slide" axis="0 0 1" limited="false" />
      <geom name="torso_geom" type="capsule" fromto="0 0 0.25 0 0 -0.25" size="0.05" />
      <body name="right_thigh" pos="0 -0.1 -0.2">
        <joint name="right_hip" type="hinge" axis="0 1 0" range="-30 30" />
        <geom name="right_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.045"
          rgba="0.8 0.2 0.2 1" />
        <body name="right_shin" pos="0 0 -0.4">
          <joint name="right_knee" type="hinge" axis="0 1 0" range="-90 0" />
          <geom name="right_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.3" size="0.035"
            rgba="0.2 0.8 0.2 1" />
          <body name="right_foot" pos="0 0 -0.3">
            <joint name="right_ankle" type="hinge" axis="0 1 0" range="-30 30" />
            <geom name="right_foot_geom" type="capsule" fromto="-0.05 0 0 0.15 0 0" size="0.04"
              rgba="0.2 0.2 0.8 1" />
          </body>
        </body>
      </body>
      <body name="left_thigh" pos="0 0.1 -0.2">
        <joint name="left_hip" type="hinge" axis="0 1 0" range="-30 30" />
        <geom name="left_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.045"
          rgba="0.2 0.8 0.2 1" />
        <body name="left_shin" pos="0 0 -0.4">
          <joint name="left_knee" type="hinge" axis="0 1 0" range="-90 0" />
          <geom name="left_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.3" size="0.035"
            rgba="0.8 0.2 0.2 1" />
          <body name="left_foot" pos="0 0 -0.3">
            <joint name="left_ankle" type="hinge" axis="0 1 0" range="-30 30" />
            <geom name="left_foot_geom" type="capsule" fromto="-0.05 0 0 0.15 0 0" size="0.04"
              rgba="0.2 0.2 0.8 1" />
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor name="left_hip_motor" joint="left_hip" gear="100" ctrlrange="-1 1" ctrllimited="true" />
    <motor name="left_knee_motor" joint="left_knee" gear="50" ctrlrange="-1 1" ctrllimited="true" />
    <motor name="left_ankle_motor" joint="left_ankle" gear="20" ctrlrange="-1 1" ctrllimited="true" />
    <motor name="right_hip_motor" joint="right_hip" gear="100" ctrlrange="-1 1" ctrllimited="true" />
    <motor name="right_knee_motor" joint="right_knee" gear="50" ctrlrange="-1 1" ctrllimited="true" />
    <motor name="right_ankle_motor" joint="right_ankle" gear="20" ctrlrange="-1 1"
      ctrllimited="true" />
  </actuator>
</mujoco>